# ---------------------------------------------------------------------
# Ktor / Kotlin / Gradle 核心构建产物
# ---------------------------------------------------------------------
.gradle/
build/
out/
.kotlin/

# ---------------------------------------------------------------------
# 本地环境配置与敏感信息（极其重要）
# ---------------------------------------------------------------------
# 本地环境变量配置文件（通常包含数据库密码、JWT 密钥等）
.env
.env.local

# Ktor 默认的配置文件（如果包含明文敏感密码，建议忽略并生成 *.sample 模版）
# application.conf
# application.yaml

# ---------------------------------------------------------------------
# IDE 缓存与配置文件 (IntelliJ IDEA)
# ---------------------------------------------------------------------
.idea/
*.iml
*.iws

# 如果团队需要共享 IDEA 的运行配置或代码风格，可以取消忽略以下目录：
# !.idea/runConfigurations/
# !.idea/codeStyles/

# ---------------------------------------------------------------------
# 操作系统缓存文件
# ---------------------------------------------------------------------
.DS_Store
Thumbs.db
